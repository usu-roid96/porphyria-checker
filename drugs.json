[  { "name_en": "$names = Get-Clipboard", "name_jp": "$names = Get-Clipboard", "status": "Safe", "category": "NAPOS Data" },
  { "name_en": "$json = @()", "name_jp": "$json = @()", "status": "Safe", "category": "NAPOS Data" },
  { "name_en": "foreach ($n in $names) {", "name_jp": "foreach ($n in $names) {", "status": "Safe", "category": "NAPOS Data" },
  { "name_en": "$c = $n.trim().replace('', '')", "name_jp": "$c = $n.trim().replace('', '')", "status": "Safe", "category": "NAPOS Data" },
  { "name_en": "$json +=   { `name_en`: `$c`, `name_jp`: `$c`, `status`: `Safe`, `category`: `NAPOS Data` }", "name_jp": "$json +=   { `name_en`: `$c`, `name_jp`: `$c`, `status`: `Safe`, `category`: `NAPOS Data` }", "status": "Safe", "category": "NAPOS Data" },
  { "name_en": "}", "name_jp": "}", "status": "Safe", "category": "NAPOS Data" },
  { "name_en": "}", "name_jp": "}", "status": "Safe", "category": "NAPOS Data" },
  { "name_en": "$content = [ + ($json -join ,`n) + ]", "name_jp": "$content = [ + ($json -join ,`n) + ]", "status": "Safe", "category": "NAPOS Data" },
  { "name_en": "# UTF8（BOMなし）で保存して文字化けを完全に封じ込める", "name_jp": "# UTF8（BOMなし）で保存して文字化けを完全に封じ込める", "status": "Safe", "category": "NAPOS Data" },
  { "name_en": "[System.IO.File]::WriteAllText($(Get-Location)/drugs.json, $content, (New-Object System.Text.UTF8Encoding($false)))", "name_jp": "[System.IO.File]::WriteAllText($(Get-Location)/drugs.json, $content, (New-Object System.Text.UTF8Encoding($false)))", "status": "Safe", "category": "NAPOS Data" }]